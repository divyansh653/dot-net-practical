@model List<_23_july.Models.Stationery>

@{
    ViewData["Title"] = "Stationery List";
}

<h2>Stationery List</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Price</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ID</td>
                <td>@item.Name</td>
                <td>@item.Price</td>
            </tr>
        }
    </tbody>
</table>

<br />

<a asp-controller="Product"
   asp-action="Index"
   class="btn btn-success">
    View Product
</a>

&nbsp;&nbsp;

<a asp-controller="Stationery"
   asp-action="Index"
   class="btn btn-primary">
    View Stationery
</a>

&nbsp;&nbsp;

<a asp-controller="Home"
   asp-action="Logout"
   class="btn btn-danger">
    Logout
</a>